# Atlas_V2 demo environment.
# Copy to .env on the EC2 box:  cp .env.prod.example .env  (then fill in values)
# Rotate before any real demo — these are placeholders.

# Public URL of the deployment (used to build NEXT_PUBLIC_API_URL + Grafana root URL).
# HTTP first, switch to https:// after certbot succeeds.
PUBLIC_URL=http://REPLACE_WITH_EC2_PUBLIC_DNS_OR_DOMAIN

# --- Postgres ---
POSTGRES_USER=atlas
POSTGRES_PASSWORD=REPLACE_WITH_openssl_rand_hex_24
POSTGRES_DB=atlas_db
DATABASE_URL=postgresql://atlas:REPLACE_WITH_openssl_rand_hex_24@db:5432/atlas_db

# --- Redis / Mongo (internal, no auth needed on the private docker network) ---
REDIS_URL=redis://redis:6379
MONGO_URL=mongodb://mongodb:27017

# --- Auth ---
JWT_SECRET_KEY=REPLACE_WITH_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=60

# --- Grafana admin ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=REPLACE_WITH_openssl_rand_hex_16

# --- App ---
ENVIRONMENT=production
LOG_LEVEL=INFO
