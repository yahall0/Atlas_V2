{
  "dashboard": {
    "title": "ATLAS Mindmap Module",
    "uid": "atlas-mindmap",
    "tags": ["atlas", "mindmap", "fir"],
    "timezone": "browser",
    "panels": [
      {
        "title": "Mindmaps Generated (Total)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "sum(atlas_mindmap_generated_total)",
            "legendFormat": "Total"
          }
        ]
      },
      {
        "title": "Mindmaps Generated by Case Category",
        "type": "piechart",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
        "targets": [
          {
            "expr": "sum by (case_category) (atlas_mindmap_generated_total)",
            "legendFormat": "{{case_category}}"
          }
        ]
      },
      {
        "title": "Generation Duration (P95)",
        "type": "gauge",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(atlas_mindmap_generation_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "P95"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 2 },
                { "color": "red", "value": 3 }
              ]
            },
            "unit": "s",
            "max": 5
          }
        }
      },
      {
        "title": "Node Status Changes Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "sum by (from_status, to_status) (rate(atlas_mindmap_node_status_changes_total[5m]))",
            "legendFormat": "{{from_status}} → {{to_status}}"
          }
        ]
      },
      {
        "title": "Hash Chain Violations (ALERT)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "atlas_mindmap_hash_chain_violations_total",
            "legendFormat": "Violations"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "red", "value": 1 }
              ]
            }
          }
        }
      },
      {
        "title": "Generation Duration Distribution",
        "type": "histogram",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
        "targets": [
          {
            "expr": "sum(rate(atlas_mindmap_generation_duration_seconds_bucket[5m])) by (le)",
            "legendFormat": "{{le}}"
          }
        ]
      }
    ],
    "refresh": "30s",
    "time": { "from": "now-1h", "to": "now" }
  }
}
